# Copy to .env on the server and fill in real values.
# Never commit .env with real secrets to Git.

DEBUG=False
SECRET_KEY=generate-a-long-random-string-50-chars

# Comma-separated: your domain(s) and the host your platform gives (e.g. app.railway.app)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com,yourapp.up.railway.app

# Comma-separated: exact frontend URL(s) with https://
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database (MySQL)
DB_ENGINE=mysql
DB_NAME=easytest
DB_USER=easytest
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=3306

# If using SQLite instead (e.g. small single-server deploy):
# DB_ENGINE=sqlite

# AI question generation — QUESTION_AI_PROVIDERS (comma-separated: openai, groq, gemini)
# Default order tries OpenAI (GPT) first, then Groq, then Gemini. Override if needed.
QUESTION_AI_PROVIDERS=openai,groq,gemini

GROQ_API_KEY=your-groq-api-key
# Optional: llama-3.1-8b-instant (fast) or llama-3.3-70b-versatile (high quality)
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI GPT (Chat Completions) — used when "openai" appears in QUESTION_AI_PROVIDERS
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: gpt-4o-mini (default), gpt-4o, gpt-4.1-mini, etc.
OPENAI_MODEL=gpt-4o-mini
# Optional: Azure OpenAI or proxy — overrides default https://api.openai.com/v1
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment

# Optional: Google Gemini (free tier key)
# GEMINI_API_KEY=your-gemini-api-key
